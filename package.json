{
  "name": "passkeys-demo",
  "version": "1.0.0",
  "description": "Passkeys Demo",
  "main": "server.mjs",
  "type": "module",
  "scripts": {
    "build": "webpack",
    "dev": "NODE_ENV=localhost node server.mjs",
    "start": "node server.mjs",
    "deploy": "npm run build && gcloud app deploy --project passkeys-demo app.yaml",
    "emulator": "firebase emulators:start --only firestore --project passkeys-demo --import=./.data --export-on-exit",
    "clean": "rm -rf node_modules package-lock.json *-debug.log .data/ firebase-debug.log ui-debug.log firebase-export-*"
  },
  "dependencies": {
    "@google-cloud/firestore": "^7.11.0",
    "@material/web": "^2.4.1",
    "base64url": "^3.0.1",
    "dotenv": "^16.1.3",
    "express": "^4.18.2",
    "express-handlebars": "^7.0.7",
    "express-session": "^1.17.3",
    "express-useragent": "^1.0.15",
    "firebase-admin": "^13.8.0",
    "firebase-functions": "^6.3.0",
    "firebase-tools": "^15.15.0",
    "lit": "^2.7.4",
    "material-components-web": "^14.0.0",
    "openid-client": "^5.4.3"
  },
  "overrides": {
    "firebase-admin": "$firebase-admin",
    "@google-cloud/storage": "^7.0.0"
  },
  "engines": {
    "node": ">=22"
  },
  "repository": {
    "url": "https://github.com/kura-lab/seccamp2026-testapp"
  },
  "license": "Apache-2.0",
  "keywords": [
    "node",
    "express",
    "webauthn",
    "fido2",
    "passkey"
  ],
  "devDependencies": {
    "@babel/core": "^7.22.1",
    "babel-loader": "^9.1.2",
    "babel-preset-env": "^0.0.0",
    "css-loader": "^6.8.1",
    "extract-loader": "^4.0.3",
    "file-loader": "^6.2.0",
    "firebase-tools": "^15.15.0",
    "html-webpack-plugin": "^5.6.3",
    "mini-css-extract-plugin": "^2.9.4",
    "sass": "^1.62.1",
    "sass-loader": "^13.3.1",
    "webpack": "^5.85.0",
    "webpack-cli": "^5.1.1"
  }
}
